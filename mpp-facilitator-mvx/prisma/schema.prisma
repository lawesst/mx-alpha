generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  channelId            String   @id
  employer             String
  receiver             String
  tokenId              String
  amountLocked         String
  amountSettled        String   @default("0")
  lastVoucherAmount    String   @default("0")
  lastVoucherNonce     BigInt   @default(0)
  lastVoucherSignature String?
  status               String   @default("OPEN")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SettlementRecord {
  id                     String    @id
  receiver               String?
  amount                 String?
  currency               String?
  chainId                String?
  payer                  String?
  status                 String    @default("pending")
  txHash                 String?
  expiresAt              DateTime?
  opaque                 String?
  digest                 String?
  source                 String?
  verificationAttempts   Int       @default(0)
  lastVerificationAt     DateTime?
  lastVerificationStatus String?
  lastVerificationError  String?
  lastObservedTxStatus   String?
  lastVerificationTxHash String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model AuditReport {
  id                  String   @id @default(cuid())
  schemaVersion       Int
  kind                String
  status              String
  endpoint            String
  generatedAt         DateTime
  sender              String
  facilitatorBaseUrl  String
  receipt             String?
  paymentTxHash       String?
  errorKinds          String   @default("[]")
  requestJson         String
  executionPolicyJson String?
  resultJson          String
  reportJson          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([endpoint, generatedAt])
  @@index([status, generatedAt])
  @@index([paymentTxHash, generatedAt])
}
